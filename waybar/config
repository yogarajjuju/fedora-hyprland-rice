{
  "layer": "top",
  "position": "top",
  "margin-top": 8,
  "margin-left": 15,
  "margin-right": 15,
  "spacing": 12,

  "modules-left": ["hyprland/workspaces"],
 "modules-center": ["clock", "mpris", "custom/cava"],
  "modules-right": [

    "custom/net",
    "cpu",
    "temperature",
    "network",
    "pulseaudio",
    "bluetooth",
    "battery",
    "custom/power"
  ],

  "hyprland/workspaces": {
    "format": "{name}"
  },

  "mpris": {
    "format": " {title}",
    "max-length": 20
  },

  "cpu": {
    "format": " {usage}%"
  },

  "temperature": {
    "format": " {temperatureC}°"
  },

  "network": {
    "format-wifi": "",
    "format-disconnected": "󰖪",
    "on-click": "/home/juju/.config/waybar/wifi.sh"
  },

  "pulseaudio": {
    "format": " {volume}%"
  },

  "battery": {
  "format": "{icon} {capacity}%",
  "format-charging": "⚡ {capacity}%",
  "format-icons": ["","","","",""]
},

  "custom/power": {
    "format": "",
    "on-click": "/home/juju/.config/waybar/powermenu.sh"
  },



  "custom/net": {
    "exec": "/home/juju/.config/waybar/net.sh",
    "interval": 2
  },
  "bluetooth": {
    "format": " {status}",
    "format-disabled": " off",
    "format-connected": " {device_alias}",
    "tooltip": true,
    "on-click": "blueman-manager",
    "on-click-right": "rfkill toggle bluetooth"
},
"custom/cava": {
    "exec": "~/.config/waybar/cava.sh",
    "return-type": "text",
    "interval": 0.1
}

}
